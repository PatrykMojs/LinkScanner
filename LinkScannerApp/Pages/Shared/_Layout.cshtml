<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkScannerApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LinkScannerApp.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1317665080022510" crossorigin="anonymous"></script>
</head>
<body class="app-body d-flex flex-column min-vh-100">

    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
            <div class="container app-navbar-container">

                <a class="navbar-brand app-brand d-flex align-items-center" asp-area="" asp-page="/Index">
                    <span class="brand-icon">
                        <i class="bi bi-shield-check"></i>
                    </span>
                    <span class="brand-text">LinkScanner</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Przełącz nawigację">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav app-nav ms-lg-5 me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link active" asp-area="" asp-page="/Index">
                                <i class="bi bi-search"></i>
                                <span>Skanuj</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/History/Index">
                                <i class="bi bi-clock-history"></i>
                                <span>Historia</span>
                                <span id="historyCount" class="badge rounded-pill bg-info text-dark ms-1 d-none">0</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main flex-grow-1">
        <div class="decor decor-left"></div>
        <div class="decor decor-right"></div>

        <div class="container app-container">
            <section class="app-card">
                @RenderBody()
            </section>
        </div>
    </main>

    <footer class="app-footer mt-auto">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

            <div class="footer-brand text-muted">
                <i class="bi bi-shield-check me-2"></i>
                <span>&copy; 2025 LinkScannerApp</span>
            </div>

            <div class="footer-links d-flex flex-wrap justify-content-center align-items-center gap-3 small">
                <a asp-page="/About">O projekcie</a>
                <span class="footer-separator">|</span>
                <a asp-page="/Privacy">Polityka prywatności</a>
                <span class="footer-separator">|</span>
                <a asp-page="/Terms">Regulamin</a>
            </div>

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            try {
                const items = JSON.parse(sessionStorage.getItem('scanHistory') || '[]');
                const el = document.getElementById('historyCount');

                if (el && items.length > 0) {
                    el.textContent = items.length;
                    el.classList.remove('d-none');
                }
            } catch { }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
